generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "mysql"
  url       = env("DATABASE_URL")
  // Aiven requires SSL — sslaccept skips cert verification for managed cloud DBs
  relationMode = "prisma"
}

// NextAuth schema
model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          UserRole  @default(STUDENT)

  accounts      Account[]
  sessions      Session[]

  quizzes       Quiz[]
  hostedSessions LiveSession[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum UserRole {
  TEACHER
  STUDENT
}

enum SessionStatus {
  WAITING
  ACTIVE
  FINISHED
}

model Quiz {
  id          String   @id @default(uuid())
  teacherId   String
  title       String
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teacher     User          @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  questions   Question[]
  sessions    LiveSession[]

  @@index([teacherId])
}

model Question {
  id             String   @id @default(uuid())
  quizId         String
  questionText   String   @db.Text
  questionType   String   @default("mcq") // 'mcq', 'true_false', 'multi_select'
  options        Json     // Array of {text: string, is_correct: boolean}
  timeLimit      Int      @default(40)
  basePoints     Int      @default(100)
  orderIndex     Int
  createdAt      DateTime @default(now())

  quiz           Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  studentResponses StudentResponse[]

  @@index([quizId])
}

model LiveSession {
  id                   String        @id @default(uuid())
  joinCode             String        @unique @db.VarChar(6)
  quizId               String
  teacherId            String
  status               SessionStatus @default(WAITING)
  currentQuestionIndex Int           @default(0)
  startedAt            DateTime?
  finishedAt           DateTime?

  quiz                 Quiz          @relation(fields: [quizId], references: [id], onDelete: Cascade)
  teacher              User          @relation(fields: [teacherId], references: [id])
  participants         Participant[]
  studentResponses     StudentResponse[]

  @@index([quizId])
  @@index([teacherId])
}

model Participant {
  id          String   @id @default(uuid())
  sessionId   String
  deviceUuid  String
  displayName String
  score       Int      @default(0)
  streak      Int      @default(0)
  cheatFlags  Int      @default(0)
  lastActive  DateTime @default(now())
  joinedAt    DateTime @default(now())

  session     LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  responses   StudentResponse[]

  @@unique([sessionId, deviceUuid])
  @@index([sessionId])
}

model StudentResponse {
  id             String   @id @default(uuid())
  sessionId      String
  participantId  String
  questionId     String
  reactionTimeMs Int
  isCorrect      Boolean
  pointsAwarded  Int      @default(0)
  streakBonus    Int      @default(0)
  answeredAt     DateTime @default(now())

  session        LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  participant    Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  question       Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([participantId])
  @@index([questionId])
}
